ENV=development
DATABASE_URL=postgresql+psycopg2://postgres:kavi@localhost:5432/kavi
FRONTEND_URL=http://localhost:5173

FIREBASE_PROJECT_ID=your-firebase-project-id
# Set one of these:
FIREBASE_CREDENTIALS_PATH=./secrets/firebase-service-account.json
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}

GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8000/api/github/callback
GITHUB_STATE_SECRET=generate_a_long_random_secret_here

TOKEN_ENCRYPTION_KEY=generate_a_real_fernet_key_here

AI_PROVIDER=gemini
AI_MODEL=gemini-1.5-flash
AI_API_KEY=your_gemini_key

RATE_LIMIT_REQUESTS_PER_MINUTE=120
MAX_REQUEST_BODY_BYTES=262144
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
OUTBOUND_RETRY_ATTEMPTS=3
OUTBOUND_CIRCUIT_BREAKER_THRESHOLD=5
OUTBOUND_CIRCUIT_BREAKER_SECONDS=90
SYNC_WORKER_POLL_SECONDS=5
SYNC_JOB_MAX_ATTEMPTS=4
SYNC_JOB_RETRY_DELAY_SECONDS=30
SYNC_JOB_STALE_AFTER_SECONDS=900
